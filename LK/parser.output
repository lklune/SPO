Grammar

    0 $accept: source $end

    1 source: %empty
    2       | source sourceItem

    3 sourceItem: DEF funcSignature listStatement END

    4 listSourceItem: sourceItem listSourceItem
    5               | %empty

    6 funcSignature: IDENTIFIER LPAREN listArgDef RPAREN optionalTypeRef

    7 listArgDef: %empty
    8           | argDef
    9           | argDef COMMA listArgDef

   10 argDef: IDENTIFIER optionalTypeRef

   11 optionalTypeRef: %empty
   12                | LPAREN OF typeRef RPAREN

   13 typeRef: builtin
   14        | custom
   15        | array

   16 builtin: TYPEDEF

   17 statement: var
   18          | if
   19          | loop
   20          | repeat
   21          | block
   22          | break
   23          | expression

   24 listStatement: statement listStatement
   25              | %empty

   26 custom: IDENTIFIER

   27 array: typeRef ARRAY LBRACKET DEC RBRACKET

   28 if: IF expr THAN statement optionalElseStatement

   29 optionalElseStatement: ELSE statement optionalElseStatement
   30                      | ELSE statement
   31                      | %empty

   32 block: LBRACE listStatement RBRACE
   33      | BEGIN_BLOCK listStatement END
   34      | LBRACE listSourceItem RBRACE
   35      | BEGIN_BLOCK listSourceItem END
   36      | LBRACE RBRACE
   37      | BEGIN_BLOCK END

   38 loop: WHILE expr listStatement END
   39     | UNTIL expr listStatement END

   40 repeat: statement WHILE expr SEMICOLON
   41       | statement UNTIL expr SEMICOLON

   42 break: BREAK SEMICOLON

   43 expression: expr SEMICOLON

   44 assignment: expr EQUAL expr

   45 expr: unary
   46     | binary
   47     | braces
   48     | call
   49     | slice
   50     | place
   51     | literal

   52 binary: assignment
   53       | expr PLUS expr
   54       | expr MINUS expr
   55       | expr STAR expr
   56       | expr SLASH expr
   57       | expr PERCENT expr
   58       | expr EQUAL EQUAL expr
   59       | expr NOTEQUAL expr
   60       | expr LESSTHAN expr
   61       | expr GREATERTHAN expr
   62       | expr LESSTHANEQ expr
   63       | expr GREATERTHANEQ expr
   64       | expr AND expr
   65       | expr OR expr

   66 unary: PLUS expr
   67      | MINUS expr
   68      | NOT expr

   69 braces: LPAREN expr RPAREN

   70 call: IDENTIFIER LPAREN optionalListExpr RPAREN

   71 optionalListExpr: listExpr
   72                 | %empty

   73 listExpr: expr COMMA listExpr
   74         | expr

   75 slice: expr LBRACKET listRange RBRACKET

   76 range: expr DOUBLE_DOT expr
   77      | expr

   78 listRange: range COMMA listRange
   79          | range

   80 place: IDENTIFIER

   81 literal: TRUE
   82        | FALSE
   83        | STR
   84        | CHAR
   85        | HEX
   86        | BIN
   87        | DEC

   88 listVarDeclared: listVarDeclaredItem COMMA listVarDeclared
   89                | listVarDeclaredItem

   90 listVarDeclaredItem: IDENTIFIER
   91                    | assignment

   92 var: typeRef listVarDeclared SEMICOLON


